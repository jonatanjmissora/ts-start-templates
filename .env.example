# Better Auth Configuration
# Requerido para que los callbacks y redirecciones funcionen correctamente
# Nota: En Vite, las variables del cliente necesitan el prefijo VITE_
VITE_BETTER_AUTH_BASE_URL=http://localhost:3000

# Para el servidor (sin prefijo VITE_)
BETTER_AUTH_BASE_URL=http://localhost:3000

# Database Configuration (ejemplo para Neon PostgreSQL)
DATABASE_URL=postgresql://username:password@hostname:5432/database_name?sslmode=require

# Otras variables de entorno que necesites
# NODE_ENV=development
